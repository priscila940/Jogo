name: Compilar Jogo e Criador de Instalador

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

jobs:
  build-windows:
    runs-on: windows-latest

    steps:
    - name: Baixar o código do repositório
      uses: actions/checkout@v4

    - name: Configurar o Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.11'

    - name: Instalar Dependências do Python
      run: |
        python -m pip install --upgrade pip
        pip install pyinstaller

    - name: Instalar Inno Setup no Servidor
      run: |
        choco install innosetup -y

    - name: Compilar o executável (.exe) direto pelo terminal
      run: |
        cd Jogo
        pyinstaller --onefile --noconsole --name=GlitchOut main.py

    - name: Compilar o Instalador (Inno Setup)
      run: |
        $env:PATH += ";C:\Program Files (x86)\Inno Setup 6"
        cd Jogo
        iscc installer_config.iss

    - name: Salvar o Instalador Pronto (Artifact)
      uses: actions/upload-artifact@v4
      with:
        name: GlitchOut-Instalador
        path: Jogo/Output_Installer/GlitchOut_Setup.exe
