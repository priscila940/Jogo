# setup_compiler.py
import subprocess
import os

def build():
    print("Iniciando a compilação do GlitchOut para .exe...")
    
    # Comando do PyInstaller configurado para o seu main.py
    comando = [
        "pyinstaller",
        "--onefile",
        "--noconsole", 
        "--name=GlitchOut",
        "main.py"
    ]
    
    try:
        subprocess.run(comando, check=True)
        print("\n[SUCESSO] O executável do seu jogo foi gerado na pasta './dist/GlitchOut.exe'")
    except subprocess.CalledProcessError:
        print("\n[ERRO] Falha ao compilar. Certifique-se de ter o PyInstaller instalado (pip install pyinstaller).")

if __name__ == "__main__":
    build()
